BOT_TOKEN=your-telegram-bot-token

# Modo recomendado en Render: webhook.
# Localmente puedes cambiarlo a polling si no tienes URL pública.
TELEGRAM_MODE=webhook

# URL pública del servicio cuando despliegas en Render.
# Ejemplo: https://reto-bot.onrender.com
WEBHOOK_BASE_URL=

# Ruta interna que recibirá los updates de Telegram.
WEBHOOK_PATH=/telegram/webhook

# Opcional pero recomendado para validar llamadas del webhook.
WEBHOOK_SECRET_TOKEN=

# PORT lo inyecta el proveedor en producción. Localmente puedes omitirlo.
SCORE_INCREMENT=1
TURN_TIMEOUT_SECONDS=15
DASHBOARD_PORT=3000
